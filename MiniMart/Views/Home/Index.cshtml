@{
    ViewBag.Title = "Home";
}

<div class="container">

    <!-- HERO SECTION -->

    <div class="row align-items-center mt-5">

        <div class="col-md-6">

            <h1 style="font-size:55px;
                       font-weight:bold;
                       color:#6a11cb;">

                Welcome To MiniMart

            </h1>

            <p class="mt-4 text-secondary"
               style="font-size:20px;">

                Discover amazing products from multiple categories
                including electronics, fashion, food, accessories,
                shoes and much more.

            </p>

            <div class="mt-4">

                <a href="/Product/Index"
                   class="btn btn-lg text-white"
                   style="background:#6a11cb;
                          border-radius:30px;
                          padding:12px 35px;">

                    Explore Products

                </a>

            </div>

        </div>

        <div class="col-md-6 text-center">

            <img src="https://cdn-icons-png.flaticon.com/512/3081/3081559.png"
                 width="450"
                 class="img-fluid" />

        </div>

    </div>

    <!-- FEATURES -->

    <div class="row mt-5 text-center">

        <div class="col-md-3">

            <div class="custom-card">

                <h2>📦</h2>

                <h4 class="mt-3">
                    Fast Delivery
                </h4>

                <p class="text-secondary">
                    Quick and safe delivery services.
                </p>

            </div>

        </div>

        <div class="col-md-3">

            <div class="custom-card">

                <h2>🛒</h2>

                <h4 class="mt-3">
                    Best Products
                </h4>

                <p class="text-secondary">
                    High quality branded products.
                </p>

            </div>

        </div>

        <div class="col-md-3">

            <div class="custom-card">

                <h2>💳</h2>

                <h4 class="mt-3">
                    Secure Payment
                </h4>

                <p class="text-secondary">
                    Trusted and secure payments.
                </p>

            </div>

        </div>

        <div class="col-md-3">

            <div class="custom-card">

                <h2>⭐</h2>

                <h4 class="mt-3">
                    Top Rated
                </h4>

                <p class="text-secondary">
                    Best customer rated items.
                </p>

            </div>

        </div>

    </div>

</div>